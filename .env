# .env.example
# Kopyala: cp .env.example .env
# .env dosyası asla git'e commit edilmemeli (.gitignore'da olmalı)

# ── Next.js ──────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ── Redis (Docker Compose içinde sabit) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Dosya depolama (Docker volume bind mount) ─────────────────────────────
STORAGE_PATH=/data/videos

# ── Python pipeline servisi URL ──────────────────────────────────────────
PIPELINE_URL=http://localhost:8001

# ── (İleride) Harici servisler ────────────────────────────────────────────
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=
# DEEPL_API_KEY=